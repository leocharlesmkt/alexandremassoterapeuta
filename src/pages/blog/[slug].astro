---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import TopBar from "../../components/TopBar.astro";
import Footer from "../../components/Footer.astro";
import { blogPosts } from "../../data/blog";
import { siteConfig } from "../../data/site.config";

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const businessName = "Alexandre Massoterapeuta";
const whatsappUrl = "https://wa.me/5519999803939?text=Ol%C3%A1%2C%20gostaria%20de%20tirar%20uma%20d%C3%BAvida%20sobre%20os%20atendimentos.";
const canonical = `${siteConfig.canonicalUrl}/blog/${post.slug}/`;
const otherPosts = blogPosts.filter((item) => item.slug !== post.slug).slice(0, 2);
const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  description: post.description,
  image: new URL(post.image, siteConfig.canonicalUrl).toString(),
  datePublished: post.date,
  author: {
    "@type": "Organization",
    name: businessName
  },
  publisher: {
    "@type": "Organization",
    name: businessName
  },
  mainEntityOfPage: canonical
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: post.faq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer
    }
  }))
};
---

<BaseLayout title={`${post.title} | ${businessName}`} description={post.description} canonical={canonical} image={post.image} type="article" schema={[schema, faqSchema]}>
  <TopBar />
  <Header />
  <main class="internal-page">
    <article class="article-shell">
      <header class="article-hero">
        <div class="container article-hero-grid">
          <div>
            <p class="eyebrow">{post.category}</p>
            <h1>{post.title}</h1>
            <p>{post.description}</p>
          </div>
          <img src={post.image} width="1200" height="675" alt={`Capa do artigo ${post.title}`} loading="eager" fetchpriority="high" decoding="async" />
        </div>
      </header>

      <div class="container content-grid article-body-grid">
        <div class="content-card article-content">
          {post.sections.map((section) => (
            <section>
              <h2>{section.heading}</h2>
              {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            </section>
          ))}

          <section>
            <h2>Perguntas frequentes</h2>
            {post.faq.map((item) => (
              <div>
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </div>
            ))}
          </section>
        </div>

        <aside class="content-card highlight-card">
          <h2>Quer tirar uma dúvida?</h2>
          <p>Fale diretamente com Alexandre para entender os atendimentos e verificar a disponibilidade.</p>
          <a class="btn" href={whatsappUrl} target="_blank" rel="noopener">Falar com Alexandre pelo WhatsApp</a>
        </aside>
      </div>
    </article>

    <section class="section section-soft">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Continue lendo</p>
          <h2>Outros conteudos do blog</h2>
        </div>
        <div class="mini-card-grid">
          {otherPosts.map((item) => (
            <a class="mini-card" href={`/blog/${item.slug}/`}>
              <img src={item.image} width="1200" height="675" alt={`Capa do artigo ${item.title}`} loading="lazy" decoding="async" />
              <strong>{item.title}</strong>
              <span>Leia mais</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
