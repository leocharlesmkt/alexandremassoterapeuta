---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import TopBar from "../../components/TopBar.astro";
import Footer from "../../components/Footer.astro";
import { blogPosts } from "../../data/blog";
import { siteConfig } from "../../data/site.config";
---

<BaseLayout
  title="Blog de Massagem Tântrica em Campinas | Alexandre Massoterapeuta"
  description="Conteúdos sobre massagem tântrica para homens em Campinas, Nuru Mix Relaxante, atendimento no Cambuí e privacidade no agendamento."
  canonical={`${siteConfig.canonicalUrl}/blog/`}
>
  <TopBar />
  <Header />
  <main class="internal-page">
    <section class="internal-hero">
      <div class="container internal-hero-grid">
        <div>
          <p class="eyebrow">Blog</p>
          <h1>Blog de massagem tântrica em Campinas</h1>
          <p>Guias para homens que buscam atendimento reservado, Massagem Tântrica e Nuru Mix Relaxante no Cambuí.</p>
        </div>
      </div>
    </section>

    <section class="section blog-section">
      <div class="container">
        <div class="blog-grid">
          {blogPosts.map((post) => (
            <article class="blog-card">
              <img src={post.image} width="1200" height="675" alt={`Capa do artigo ${post.title}`} loading="lazy" decoding="async" />
              <div>
                <p class="blog-meta">{new Date(post.date).toLocaleDateString("pt-BR")} / {post.category}</p>
                <h2>{post.title}</h2>
                <p>{post.description}</p>
                <a href={`/blog/${post.slug}/`}>Leia mais &gt;&gt;</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
