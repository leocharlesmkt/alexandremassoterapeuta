---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import TopBar from "../../components/TopBar.astro";
import Footer from "../../components/Footer.astro";
import { services } from "../../data/services";
import { siteConfig } from "../../data/site.config";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service }
  }));
}

const { service } = Astro.props;
const canonical = `${siteConfig.canonicalUrl}/servicos/${service.slug}/`;
const relatedServices = services.filter((item) => item.slug !== service.slug).slice(0, 3);
const whatsappUrl = `https://wa.me/5519999803939?text=${encodeURIComponent(service.whatsappText)}`;
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: service.h1,
  description: service.seoDescription,
  image: new URL(service.image, siteConfig.canonicalUrl).toString(),
  areaServed: {
    "@type": "City",
    name: "Campinas"
  },
  provider: {
    "@type": "LocalBusiness",
    name: "Alexandre Massoterapeuta",
    address: {
      "@type": "PostalAddress",
      addressLocality: "Campinas",
      addressRegion: "SP",
      addressCountry: "BR"
    }
  },
  serviceType: service.localTitle
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: service.faq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer
    }
  }))
};
---

<BaseLayout
  title={`${service.seoTitle} | Alexandre Massoterapeuta`}
  description={service.seoDescription}
  canonical={canonical}
  image={service.image}
  schema={[serviceSchema, faqSchema]}
>
  <TopBar />
  <Header />
  <main class="internal-page">
    <section class="internal-hero">
      <div class="container internal-hero-grid">
        <div>
          <p class="eyebrow">Atendimento</p>
          <h1>{service.h1}</h1>
          <p>{service.intro}</p>
          <a class="btn" href={whatsappUrl} target="_blank" rel="noopener">Conversar sobre {service.title}</a>
        </div>
        <img src={service.image} width="900" height="700" alt={`${service.localTitle} em Campinas`} loading="eager" fetchpriority="high" decoding="async" />
      </div>
    </section>

    <section class="section">
      <div class="container content-grid">
        <article class="content-card">
          <p class="eyebrow">Como funciona</p>
          {service.sections.map((section) => (
            <section class="service-content-block">
              <h2>{section.heading}</h2>
              {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            </section>
          ))}

          <section class="service-content-block">
            <h2>Perguntas frequentes sobre {service.title}</h2>
            {service.faq.map((item) => (
              <div class="faq-item">
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </div>
            ))}
          </section>
        </article>

        <aside class="content-card highlight-card">
          <h2>Benefícios principais</h2>
          <ul class="check-list">
            {service.benefits.map((benefit) => <li>{benefit}</li>)}
          </ul>
          <a class="btn" href={whatsappUrl} target="_blank" rel="noopener">Falar no WhatsApp</a>
        </aside>
      </div>
    </section>

    <section class="section section-soft">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Outros atendimentos</p>
          <h2>Veja também outras massagens</h2>
        </div>
        <div class="mini-card-grid">
          {relatedServices.map((item) => (
            <a class="mini-card" href={item.href}>
              <img src={item.image} width="900" height="700" alt={`Imagem modelo de ${item.localTitle}`} loading="lazy" decoding="async" />
              <strong>{item.localTitle}</strong>
              <span>Conhecer atendimento</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
