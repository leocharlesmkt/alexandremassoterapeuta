---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import TopBar from "../../components/TopBar.astro";
import Footer from "../../components/Footer.astro";
import { services } from "../../data/services";
import { siteConfig } from "../../data/site.config";
---

<BaseLayout
  title={`Massagem Tântrica para Homens em Campinas | Atendimentos no Cambuí`}
  description={`Conheça Massagem Relaxante, Nuru Mix Relaxante e Massagem Tântrica Mútua para homens em Campinas. Atendimento privativo no Cambuí com Alexandre Massoterapeuta.`}
  canonical={`${siteConfig.canonicalUrl}/servicos/`}
>
  <TopBar />
  <Header />
  <main class="internal-page">
    <section class="internal-hero">
      <div class="container internal-hero-grid">
        <div>
          <p class="eyebrow">Atendimentos</p>
          <h1>Massagens para homens em Campinas, no Cambuí</h1>
          <p>Conheça os atendimentos realizados por Alexandre: Massagem Relaxante na maca, Nuru Mix Relaxante no tatame e Massagem Tântrica Mútua. Tudo com privacidade, discrição e horário agendado.</p>
        </div>
        <img src="/images/alexandre-galeria-atendimento.webp" width="1200" height="900" alt={`Atendimento de ${siteConfig.businessName}`} loading="eager" fetchpriority="high" decoding="async" />
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="service-grid">
          {services.map((service) => (
            <article class="service-card">
              <div class="service-body">
                <div class="service-title-row">
                  <span class="icon-pill" aria-hidden="true">+</span>
                  <h2>{service.localTitle}</h2>
                  <a class="card-arrow" href={service.href} aria-label={`Abrir página de ${service.localTitle}`}>↗</a>
                </div>
                <p>{service.description}</p>
              </div>
              <img src={service.image} width="900" height="700" alt={`Imagem modelo de ${service.localTitle}`} loading="lazy" decoding="async" />
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
