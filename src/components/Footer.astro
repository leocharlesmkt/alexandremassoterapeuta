---
const whatsappUrl = "https://wa.me/5519999803939?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20um%20atendimento.";
const whatsappDisplay = "(19) 99980-3939";
const charlesUrl = "https://wa.me/552197614920?text=Ol%C3%A1%2C%20vim%20pelo%20site%20do%20Alexandre%20e%20quero%20falar%20sobre%20cria%C3%A7%C3%A3o%20de%20site.";

const links = [
  ["Home", "/#inicio"],
  ["Sobre mim", "/#sobre"],
  ["Atendimentos", "/#servicos"],
  ["Diferenciais", "/#diferenciais"],
  ["Depoimentos", "/#depoimentos"],
  ["Blog", "/blog/"],
  ["Contato", "/#contato"]
];
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <a class="footer-logo" href="/" aria-label="Alexandre Massoterapeuta - página inicial">
        <img src="/images/alexandre-massoterapeuta-logo.svg" width="370" height="72" alt="Alexandre Massoterapeuta" loading="lazy" decoding="async" />
      </a>
    </div>
    <div>
      <h2>Sobre</h2>
      <p>Atendimento tântrico exclusivo para homens, com privacidade, conforto e discrição no Cambuí, Campinas.</p>
    </div>
    <nav aria-label="Acesso rapido">
      <h2>Acesso rapido</h2>
      {links.map(([label, href]) => <a href={href}>{label}</a>)}
    </nav>
    <div>
      <h2>Nossos contatos</h2>
      <p>Alexandre Massoterapeuta</p>
      <p>Cambuí — Campinas/SP</p>
      <p>Atendimento exclusivo para homens</p>
      <p>Somente com horário agendado</p>
      <p>WhatsApp: <a href={whatsappUrl} target="_blank" rel="noopener">{whatsappDisplay}</a></p>
    </div>
  </div>
  <div class="footer-bottom">
    <p>Site criado por Charles</p>
    <a href={charlesUrl} target="_blank" rel="noopener">Falar com Charles</a>
  </div>
</footer>

<a class="floating-whatsapp" href={whatsappUrl} target="_blank" rel="noopener" aria-label="Chamar no WhatsApp">
  <svg viewBox="0 0 32 32" aria-hidden="true">
