---
const navItems = [
  ["Início", "/#inicio", "inicio"],
  ["Atendimentos", "/#servicos", "servicos"],
  ["Sobre", "/#sobre", "sobre"],
  ["Diferenciais", "/#diferenciais", "diferenciais"],
  ["Depoimentos", "/#depoimentos", "depoimentos"],
  ["Blog", "/#blog", "blog"],
  ["Contato", "/#contato", "contato"]
];

const businessName = "Alexandre";
const whatsapp = "5519999803939";
const whatsappUrl = "https://wa.me/5519999803939?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20um%20atendimento.";
const phoneDigits = whatsapp.replace(/^55/, "");
const phoneDisplay = phoneDigits.replace(/(\d{2})(\d{5})(\d{4})/, "($1) $2-$3");
---

<header class="site-header" data-header>
  <div class="container header-inner">
    <a class="logo" href="/" aria-label={`${businessName} - pagina inicial`}>
      <img class="navbar-logo" src="/images/alexandre-massoterapeuta-logo.svg" width="370" height="72" alt="Alexandre Massoterapeuta" />
    </a>

    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-menu" data-menu-toggle>
      <span class="sr-only">Abrir menu</span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>

    <nav class="main-nav" id="site-menu" aria-label="Navegacao principal" data-menu>
      {navItems.map(([label, href, section], index) => (
        <a href={href} data-nav-link data-section={section} aria-current={index === 0 ? "page" : undefined}>
          {label}
        </a>
      ))}
    </nav>

    <a class="header-whatsapp" href={whatsappUrl} target="_blank" rel="noopener" aria-label={`Agendamentos pelo WhatsApp ${phoneDisplay}`}>
      <svg viewBox="0 0 32 32" aria-hidden="true">
        <path fill="currentColor" d="M16.02 3.2A12.72 12.72 0 0 0 5.18 22.58L3.8 28.8l6.36-1.5a12.7 12.7 0 0 0 5.86 1.43h.01A12.76 12.76 0 0 0 16.02 3.2Zm0 23.36h-.01a10.53 10.53 0 0 1-5.37-1.47l-.38-.23-3.78.9.8-3.7-.25-.39A10.55 10.55 0 1 1 16.02 26.56Zm5.8-7.9c-.32-.16-1.88-.93-2.17-1.04-.3-.1-.5-.16-.72.16-.21.32-.82 1.04-1.01 1.25-.18.22-.37.24-.69.08-.32-.16-1.34-.49-2.56-1.57-.95-.84-1.59-1.88-1.77-2.2-.19-.32-.02-.49.14-.65.14-.14.32-.37.48-.56.16-.18.21-.32.32-.53.1-.22.05-.4-.03-.56-.08-.16-.72-1.73-.98-2.37-.26-.62-.52-.54-.72-.55h-.61c-.21 0-.56.08-.85.4-.3.32-1.12 1.1-1.12 2.67 0 1.58 1.14 3.1 1.3 3.31.16.22 2.25 3.44 5.45 4.82.76.33 1.35.52 1.82.67.76.24 1.46.21 2.01.13.61-.09 1.88-.77 2.14-1.52.27-.74.27-1.38.19-1.51-.08-.14-.29-.22-.61-.38Z"/>
      </svg>
      <span>
        <small>Agendamentos pelo WhatsApp</small>
        <strong>{phoneDisplay}</strong>
      </span>
    </a>
  </div>
</header>

<script>
  const toggle = document.querySelector("[data-menu-toggle]");
  const menu = document.querySelector("[data-menu]");

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      menu.toggleAttribute("data-open", !expanded);
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        toggle.setAttribute("aria-expanded", "false");
        menu.removeAttribute("data-open");
      });
    });
  }

  const navLinks = Array.from(document.querySelectorAll("[data-nav-link]"));
  const sectionIds = navLinks
    .map((link) => link.getAttribute("data-section"))
    .filter((id): id is string => Boolean(id));

  const setActive = (id: string) => {
    navLinks.forEach((link) => {
      const active = link.getAttribute("data-section") === id;
      if (active) {
        link.setAttribute("aria-current", "page");
      } else {
        link.removeAttribute("aria-current");
      }
    });
  };

  const sections = sectionIds
    .map((id) => document.getElementById(id))
    .filter((section): section is HTMLElement => Boolean(section));

  if (sections.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (visible?.target.id) {
          setActive(visible.target.id);
        }
      },
      {
        rootMargin: "-24% 0px -58% 0px",
        threshold: [0.12, 0.24, 0.36]
      }
    );

    sections.forEach((section) => observer.observe(section));
  }
</script>
