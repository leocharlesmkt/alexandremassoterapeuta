---
import { services } from "../data/services";

const serviceImageVariants = new Map([
  ["/images/servico-massagem-relaxante.webp", "/images/servico-massagem-relaxante-360.webp 360w, /images/servico-massagem-relaxante-520.webp 520w, /images/servico-massagem-relaxante.webp 515w"],
  ["/images/servico-nuru-mix.webp", "/images/servico-nuru-mix-360.webp 360w, /images/servico-nuru-mix-520.webp 520w, /images/servico-nuru-mix.webp 582w"],
  ["/images/servico-tantrica-mutua.webp", "/images/servico-tantrica-mutua-360.webp 360w, /images/servico-tantrica-mutua-520.webp 520w, /images/servico-tantrica-mutua.webp 592w"]
]);
---

<section class="section section-soft" id="servicos">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Atendimentos</p>
      <h2>Qual atendimento você está procurando?</h2>
      <p>
        Conheça as opções de massagem realizadas em um ambiente reservado no Cambuí. Escolha a que mais combina com o seu momento e agende pelo WhatsApp.
      </p>
    </div>
    <div class="service-grid">
      {services.map((service) => (
        <article class="service-card">
          <div class="service-body">
            <div class="service-title-row">
              <span class="icon-pill" aria-hidden="true">+</span>
              <h3>{service.localTitle}</h3>
              <a class="card-arrow" href={service.href} aria-label={`Saiba mais sobre ${service.localTitle}`}>↗</a>
            </div>
            <p>{service.text}</p>
          </div>
          <img
            src={service.image}
            srcset={serviceImageVariants.get(service.image)}
            sizes="(max-width: 719px) 92vw, (max-width: 1099px) 44vw, 341px"
            width="900"
            height="700"
            alt={`Imagem modelo de ${service.localTitle}`}
            loading="lazy"
            decoding="async"
          />
        </article>
      ))}
    </div>
    <div class="center-action">
      <a class="btn btn-gold" href="/servicos/">Saiba mais sobre cada massagem</a>
    </div>
  </div>
</section>
