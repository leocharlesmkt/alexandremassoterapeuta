---
import { testimonials } from "../data/testimonials";
---

<section class="section section-soft" id="depoimentos">
  <div class="container">
    <div class="section-heading section-heading-center">
      <p class="eyebrow">Depoimentos</p>
      <h2>O que clientes dizem sobre o atendimento</h2>
      <p>Relatos de homens que buscaram discrição, conforto e um atendimento individual no Cambuí.</p>
    </div>
    <div class="reviews-grid">
      {testimonials.map((review) => (
        <article class="review-card">
          <div class="review-author">
            <span aria-hidden="true">{review.name.slice(0, 1)}</span>
            <strong>{review.name}</strong>
          </div>
          <span class="review-stars" aria-label="5 de 5 estrelas">★★★★★</span>
          <p>{review.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
